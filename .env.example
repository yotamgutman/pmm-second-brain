# Embedding provider: local | openai | hash
# "local" runs offline (downloads model on first use). Recommended.
# "hash" is dependency-free, for CI/testing only — not semantically rich.
EMBEDDING_PROVIDER=local

# LLM provider: anthropic | openai | mock
# "mock" runs the full pipeline with no API key — demo mode.
LLM_PROVIDER=anthropic

# Required if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Required if LLM_PROVIDER=openai or EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...